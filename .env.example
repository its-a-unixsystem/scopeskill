# Optional one-process overrides for sv-cli.
# Normal setup is interactive: run `sv-cli auth login` to write CUSTOMER and
# REST_REFRESH_TOKEN to the scopeskill config.

# Use a non-default scopeskill config path.
SCOPESKILL_CONFIG=

# Override the configured durable REST refresh token for this process.
SCOPESKILL_REST_REFRESH_TOKEN=

# Override the REST base URL.
SCOPESKILL_BASE_URL=

# Override the short-lived REST access-token cache path.
SCOPESKILL_ACCESS_TOKEN_CACHE=
